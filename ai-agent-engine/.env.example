# =============================================================================
# TRAVION AI ENGINE - Environment Configuration
# =============================================================================
# Copy this file to .env and fill in your API keys

# =============================================================================
# LLM CONFIGURATION
# =============================================================================
# Primary LLM Provider: "gemini", "openai", or "ollama"
LLM_PROVIDER=openai

# Google Gemini API (Free tier available)
# Get your key at: https://makersuite.google.com/app/apikey
GOOGLE_API_KEY=

# OpenAI API (Fallback)
# Get your key at: https://platform.openai.com/api-keys
OPENAI_API_KEY=your-openai-api-key-here

# Ollama (Local - no API key needed, just ensure Ollama is running)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.1:8b

# =============================================================================
# LANGSMITH MONITORING (RAG Agent Tracing)
# =============================================================================
# LangSmith provides visual monitoring of your RAG agent workflow
# 
# Setup Instructions:
# 1. Create account at: https://smith.langchain.com
# 2. Go to Settings > API Keys
# 3. Create a new API key and paste it below
# 4. View your traces at: https://smith.langchain.com/projects

# Enable LangSmith tracing (true/false)
LANGCHAIN_TRACING_V2=true

# Your LangSmith API key (required for monitoring)
LANGCHAIN_API_KEY=your-langsmith-api-key-here

# Project name for organizing traces (default: travion-ai-engine)
LANGCHAIN_PROJECT=travion-ai-engine

# LangSmith API endpoint (usually don't need to change)
LANGCHAIN_ENDPOINT=https://api.smith.langchain.com

# =============================================================================
# WEB SEARCH (Tavily)
# =============================================================================
# Used for real-time info when knowledge base is insufficient
# Get your key at: https://tavily.com
TAVILY_API_KEY=

# =============================================================================
# APPLICATION SETTINGS
# =============================================================================
DEBUG=true
ENVIRONMENT=development

# Server configuration
HOST=0.0.0.0
PORT=8001

# CORS Origins (comma-separated list or * for all)
# For production, set to your frontend domains:
# CORS_ORIGINS=https://yourdomain.com,https://app.yourdomain.com
CORS_ORIGINS=*

# =============================================================================
# RELIABILITY SETTINGS
# =============================================================================
# LLM timeout and retry configuration
LLM_TIMEOUT_SECONDS=30
LLM_MAX_RETRIES=3
LLM_RETRY_DELAY=1.0

# ChromaDB timeout
CHROMADB_TIMEOUT_SECONDS=10

# =============================================================================
# AGENT CONFIGURATION
# =============================================================================
MAX_REASONING_LOOPS=3
RETRIEVAL_TOP_K=5
RELEVANCE_THRESHOLD=0.7
MAX_WEB_SEARCH_RESULTS=5

# =============================================================================
# MCP SERVERS (Model Context Protocol)
# =============================================================================
# Google Maps MCP server for restaurant / hotel search
# 1. Get a Google Maps API key at: https://console.cloud.google.com/apis/credentials
# 2. Enable "Places API (New)" in your Google Cloud project
# 3. Run the MCP server:  docker compose up mcp-google-maps
MCP_GOOGLE_MAPS_URL=http://localhost:8010
MCP_GOOGLE_MAPS_KEY=your-google-maps-api-key-here
GOOGLE_MAPS_API_KEY=your-google-maps-api-key-here
